{
  "name": "book-management",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 5173",
    "start:api": "json-server --watch db.json --port 4000",
    "start:upload": "node upload-server.js",
    "start": "npm-run-all --parallel start:api start:upload dev",
    "test": "vitest run --environment jsdom",
    "test:watch": "vitest --environment jsdom"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "jsdom": "^29.1.1",
    "json-server": "^0.17.3",
    "npm-run-all": "^4.1.5",
    "vite": "^5.0.0",
    "vitest": "^4.1.7"
  }
}
