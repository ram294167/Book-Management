# Set this to your deployed MockAPI endpoint when running on Vercel or other hosts.
# MockAPI structure: Project /books + Resource books = /books/books
# For local development with JSON Server, use http://localhost:4000/books
VITE_API_URL=https://6a1682401b90031f81b118b5.mockapi.io/books/books

# Upload server URL (for file uploads)
# For local development, use http://localhost:5000
# For deployed, set to your upload server origin (no trailing slash)
VITE_UPLOAD_URL=http://localhost:5000
